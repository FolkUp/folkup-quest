{
  "name": "folkup-quest",
  "private": true,
  "version": "1.0.0",
  "description": "FolkUp Quest — interactive text adventure with comic panel integration (Ink engine)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/compile-ink.js && vite build",
    "preview": "vite preview",
    "compile-ink": "node scripts/compile-ink.js",
    "validate": "node scripts/validate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-icons": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/generate-pwa-icons.ps1"
  },
  "dependencies": {
    "inkjs": "^2.3.0"
  },
  "devDependencies": {
    "happy-dom": "^20.7.0",
    "node-id3": "^0.2.9",
    "sharp": "^0.34.5",
    "text-to-svg": "^3.1.5",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
