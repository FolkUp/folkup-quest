          "text": "SHHH",
          "originalCyrillic": "шшшш",
          "style": "sfx_large",
          "note": "splatter-шрифт, дождь"
        },
        {
          "type": "caption",
          "text": "PhD по нейробиологии. Три статьи в Nature. Теперь — бордовый рюкзак и восемь фунтов в час.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 5,
      "elements": [
        {
          "type": "sfx",
          "text": "KLIK",
          "originalCyrillic": "клик",
          "style": "sfx_small",
          "note": "мелко"
        }
      ]
    },
    {
      "panel": 6,
      "elements": [
        {
          "type": "caption",
          "text": "Тихо. Как бывает тихо, когда решение уже принято.",
          "style": "caption",
          "multiline": false
        }
      ]
    }
