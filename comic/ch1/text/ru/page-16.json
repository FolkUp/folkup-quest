          "hasError": false
        }
      ]
    },
    {
      "panel": 2,
      "elements": [
        {
          "type": "dan_text",
          "text": "Уверенность — это Бреус. Сомнение — это ты. Не перепутай.",
          "style": "dan_text",
          "note": null
        },
        {
          "type": "sfx",
          "text": "E7",
          "style": "sfx_amber",
          "note": "мелко, рядом с гитарой"
        }
      ]
    },
