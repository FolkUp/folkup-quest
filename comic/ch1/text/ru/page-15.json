  "panels": [
    {
      "panel": 1,
      "elements": [
        {
          "type": "caption",
          "text": "Он ушёл. Лампа перестала мерцать.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 3,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Алиса",
          "text": "Он говорил обо мне. 'Блокнот вместо портфолио.' Он не ошибся.",
          "style": "alice_text",
          "mask": null
        }
      ]
    },
    {
      "panel": 4,
      "elements": [
        {
          "type": "alice_text",
          "text": "// Портфолио показывает, что ты сделал. Блокнот показывает, что ты заметил.",
          "style": "alice_text"
        }
      ]
    },
    {
      "panel": 5,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Арни",
          "text": "Справимся. Вместе. Без чужих денег.",
          "style": "dialogue_arni",
          "mask": null
        },
        {
          "type": "caption",
          "text": "Folk choice.",
          "style": "caption_emphasis",
          "multiline": false
        }
      ]
    }
  ],
