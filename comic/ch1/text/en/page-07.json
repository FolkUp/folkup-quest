  "panels": [
    {
      "panel": 1,
      "elements": [
        {
          "type": "caption",
          "text": "Arni showed her. Empty shelves, the lamp, three doors. Everything FolkUp was \u2014 architecture without content.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 2,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Alice",
          "text": "// Two hundred articles for minimum density. With one author \u2014 four years.",
          "style": "alice_text",
          "mask": null
        }
      ]
    },
    {
      "panel": 3,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Alice",
          "text": "// I keep statistics on failures. Other people's. Don't have my own yet \u2014 nothing to start from.",
          "style": "alice_text",
          "mask": null
        }
      ]
    },
    {
      "panel": 4,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Arni",
          "text": "Let's figure it out together.",
          "style": "dialogue_arni",
          "mask": null
        },
        {
          "type": "dialogue",
          "speaker": "Alice",
          "text": "// Let me think... All right. I'll think about it.",
          "style": "alice_text",
          "mask": null
        }
      ]
    }
  ],
