{
  "page": 2,
  "lang": "en",
  "panels": [
    {
      "panel": 1,
      "elements": [
        {
          "type": "caption",
          "text": "Seagulls. Seven. I was counting them because counting seagulls is the one activity that does not require a LinkedIn profile.",
          "style": "caption",
          "order": 1
        },
        {
          "type": "caption",
          "text": "Fired a year ago. Officially \u2014 downsizing. Actually \u2014 a handshake and 'we wish you the best in your future endeavors.'",
          "style": "caption",
          "order": 2
        },
        {
          "type": "caption",
          "text": "Three months drinking. Two reading Seneca. One catching butterflies.",
          "style": "caption",
          "order": 3
        },
        {
          "type": "caption",
          "text": "Then I found a wand. Open source. Created FolkUp. Inserted the key. Opened the door. Walked in.",
          "style": "caption",
          "order": 4
        },
        {
          "type": "caption",
          "text": "Nothing inside.",
          "style": "caption_emphasis",
          "order": 5
        }
      ]
    }
  ],
