{
  "page": 13,
  "lang": "en",
  "panels": [
    {
      "panel": 1,
      "elements": [
        {
          "type": "caption",
          "text": "All three doors were open. All three \u2014 walked through. The shelves still almost empty. But 'almost' is no longer 'completely.'",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 2,
      "elements": [
        {
          "type": "sfx",
          "text": "TUK TUK TUK",
          "originalCyrillic": "\u0422\u0423\u041a \u0422\u0423\u041a \u0422\u0423\u041a",
          "style": "sfx_large",
          "note": null
        },
        {
          "type": "caption",
          "text": "A knock. Confident, measured, with a pause after the third strike. The way people knock who are used to being let in.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 3,
      "elements": []
    },
    {
      "panel": 4,
      "elements": [
        {
          "type": "caption",
          "text": "He had aged. Not the way people age from time \u2014 the way they age from money.",
          "style": "caption",
          "multiline": false
        },
        {
          "type": "dialogue",
          "speaker": "Breus",
          "text": "Arni. I recognize your work. Architecture \u2014 clean. Code \u2014 literate. The idea \u2014 beautiful.",
          "style": "dialogue_breus_mask3",
          "mask": "Mask 3"
        }
      ]
    },
    {
      "panel": 5,
      "elements": []
    }
  ],
