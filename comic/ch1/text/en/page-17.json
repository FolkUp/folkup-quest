{
  "page": 17,
  "lang": "en",
  "panels": [
    {
      "panel": 1,
      "elements": [
        {
          "type": "caption",
          "text": "Three in the morning. Everyone gone.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 2,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Reflection",
          "text": "You in five years. Or Breus twenty years ago.",
          "style": "dialogue_reflection",
          "mask": null
        }
      ]
    },
    {
      "panel": 3,
      "elements": [
        {
          "type": "caption",
          "text": "Don Rumata came to observe. Then drew his sword.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 4,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Arni",
          "text": "Show me more. What do you see?",
          "style": "dialogue_arni",
          "mask": null
        }
      ]
    },
    {
      "panel": 5,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "Arni",
          "text": "The second one.",
          "style": "dialogue_arni",
          "mask": null
        },
        {
          "type": "dialogue",
          "speaker": "Reflection",
          "text": "It will hurt.",
          "style": "dialogue_reflection",
          "mask": null,
          "direction": "off-panel, balloon tail exits left"
        },
        {
          "type": "dialogue",
          "speaker": "Arni",
          "text": "I know.",
          "style": "dialogue_arni",
          "mask": null
        }
      ]
    }
  ],
