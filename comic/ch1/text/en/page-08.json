  "panels": [
    {
      "panel": 1,
      "elements": [
        {
          "type": "caption",
          "text": "Portuguese forest. Cork oaks \u2014 stripped to the flesh. A smell on the edge between mushrooms and decay.",
          "style": "caption",
          "multiline": false
        }
      ]
    },
    {
      "panel": 2,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "CyberGonzo",
          "text": "Stop. Test. Name three inedible mushrooms of the Alentejo.",
          "style": "gonzo_text",
          "mask": null
        }
      ]
    },
    {
      "panel": 3,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "CyberGonzo",
          "text": "Webcap. Lethal. Symptoms in two weeks, when it is already too late. A blog author copied the description from a 1983 dissertation. The typo has been killing for forty years.",
          "style": "gonzo_text",
          "mask": null
        }
      ]
    },
    {
      "panel": 4,
      "elements": [
        {
          "type": "dialogue",
          "speaker": "CyberGonzo",
          "text": "The fact is dead. Its corpse keeps killing.",
          "style": "gonzo_text",
          "mask": null
        }
      ]
    }
  ],
