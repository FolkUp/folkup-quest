# SCENE: ending
# ACT: 3

// Ending determination logic
// High Folk (≥65): accept→bridge, refuse→lantern, counter→lantern(best)
// Mid (36-64): accept→bridge, refuse→lantern, counter→bridge
// High Dragon (≤35): accept→chair, refuse→bridge, counter→bridge

{
    - final_choice == "refuse" && folk_counter >= 36:
        -> ending_lantern
    - final_choice == "counter_offer" && folk_counter >= 65:
        -> ending_lantern
    - final_choice == "accept" && folk_counter <= 35:
        -> ending_chair
    - final_choice == "accept":
        -> ending_bridge
    - final_choice == "refuse" && folk_counter < 36:
        -> ending_bridge
    - final_choice == "counter_offer":
        -> ending_bridge
    - else:
        -> ending_bridge
}

